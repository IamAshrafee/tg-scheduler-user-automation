# Backend Configuration
PORT=8000
DEBUG=True

# Database
MONGO_URI=mongodb://localhost:27017
DB_NAME=telegram_automation

# Security
JWT_SECRET=your_super_secret_jwt_key_please_change_this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours

# Encryption (for session files)
# Generate one: from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
ENCRYPTION_KEY=your_fernet_key_here_must_be_base64_url_safe

# Telegram API (Get yours from https://my.telegram.org)
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=abcdef1234567890

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]

# Admin
ADMIN_EMAIL=admin@example.com

